generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum PlotStatus {
  LOCKED
  AVAILABLE
  OWNED
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)

  coins        Int      @default(1000)
  diamonds     Int      @default(10)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plots        UserPlot[]
}

model City {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true)

  plots     Plot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plot {
  id          String     @id @default(uuid())
  cityId      String
  name        String
  zone        String
  price       Int
  baseIncome  Int
  buildTime   Int        @default(60)
  status      PlotStatus @default(AVAILABLE)
  order       Int        @default(0)

  city        City       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  userPlots   UserPlot[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Building {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  price           Int
  incomePerMinute Int
  maxLevel        Int      @default(10)
  imageUrl        String?
  isActive        Boolean  @default(true)

  userPlots       UserPlot[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserPlot {
  id          String   @id @default(uuid())
  userId      String
  plotId      String
  buildingId  String?

  level       Int      @default(1)
  isBuilt     Boolean  @default(false)
  buildEndsAt DateTime?
  lastCollectAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plot        Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
  building    Building? @relation(fields: [buildingId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, plotId])
}
